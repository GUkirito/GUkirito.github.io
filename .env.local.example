# GitHub Personal Access Token (repo scope, for content CRUD)
GITHUB_TOKEN=ghp_xxxxxxxxxxxx

# GitHub OAuth App credentials (for NextAuth.js)
GITHUB_ID=your_oauth_app_client_id
GITHUB_SECRET=your_oauth_app_client_secret

# NextAuth secret (generate with: openssl rand -base64 32)
NEXTAUTH_SECRET=your_random_secret_here

# Repository name for GitHub API calls
GITHUB_REPO=GUkirito/GUkirito.github.io

# Allowed GitHub username for admin access
ALLOWED_USER=gukirito

# NextAuth URL (set to your Vercel deployment URL in production)
# NEXTAUTH_URL=https://your-project.vercel.app
